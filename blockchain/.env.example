# Wallet private key (without 0x prefix) - NEVER commit real key
PRIVATE_KEY=your_wallet_private_key_here

# Polygon Mumbai Testnet RPC
MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com

# Polygon Mainnet RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API Key (for contract verification)
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Infura / Alchemy Project ID
INFURA_PROJECT_ID=your_infura_project_id
ALCHEMY_API_KEY=your_alchemy_api_key

# Deployed contract addresses (auto-filled after deploy)
DRUG_REGISTRY_ADDRESS=
ROLE_MANAGER_ADDRESS=
QR_VERIFIER_ADDRESS=
ANOMALY_LOGGER_ADDRESS=

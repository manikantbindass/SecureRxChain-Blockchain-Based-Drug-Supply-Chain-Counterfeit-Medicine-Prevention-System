{
  "infiniteLoop": false,
  "startScript": "dev",
  "template": "node",
  "node": "18",
  "description": "SecureRxChain - Blockchain-Based Drug Supply Chain & Counterfeit Medicine Prevention System",
  "entry": "server/index.js",
  "scripts": {
    "dev": "cd server && npm install && npm run dev",
    "start": "cd server && npm start",
    "install:all": "cd server && npm install"
  },
  "directories": {
    "root": "/server"
  },
  "environment": {
    "PORT": "5000",
    "NODE_ENV": "development"
  },
  "tasks": {
    "install-dependencies": {
      "name": "Install Dependencies",
      "command": "cd server && npm install",
      "runAtStart": true
    },
    "start-server": {
      "name": "Start Express Server",
      "command": "cd server && npm run dev",
      "runAtStart": true,
      "preview": {
        "port": 5000
      }
    }
  }
}
